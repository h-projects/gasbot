{
  "name": "gasbot",
  "version": "4.1.0",
  "description": "A bot to remove and protect you from the letter G.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "changelog": "standard-changelog",
    "check": "biome check",
    "deploy": "node -C development --env-file=.env src/index.ts --deploy",
    "dev": "node -C development --watch --env-file=.env src/index.ts",
    "format": "biome format --write",
    "lint": "biome lint",
    "lint:fix": "biome lint --fix --unsafe",
    "start": "NODE_ENV=production node --env-file=.env --enable-source-maps .",
    "test": "node --run check && node --run typecheck",
    "typecheck": "tsc --noEmit"
  },
  "imports": {
    "#*": {
      "development": "./src/*/index.ts",
      "default": "./dist/*/index.js"
    }
  },
  "dependencies": {
    "@discordjs/builders": "2.0.0-pr-11006.1765452229-e636950b2",
    "bufferutil": "^4.1.0",
    "dedent": "^1.7.2",
    "discord.js": "15.0.0-pr-11006.1765452229-e636950b2",
    "g-detector": "^1.0.0",
    "typed-env": "^2.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.1",
    "standard-changelog": "^7.0.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.4.0"
  },
  "packageManager": "pnpm@11.1.3"
}
